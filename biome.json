{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "root": true,
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": ["**"]
          }
        }
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "nursery": {
        "useExplicitType": "off"
      },
      "correctness": {
        "noUndeclaredDependencies": "off",
        "useImportExtensions": "off",
        "noUndeclaredVariables": "off",
        "noNodejsModules": "off",
        "noUnusedImports": { "level": "on", "fix": "safe", "options": {} }
      },
      "style": {
        "noImplicitBoolean": "off",
        "useDefaultSwitchClause": "off",
        "useNamingConvention": "off",
        "noParameterProperties": "off",
        "useComponentExportOnlyModules": "off",
        "noEnum": "off",
        "useConsistentMemberAccessibility": "off",
        "useConsistentCurlyBraces": "off",
        "noProcessEnv": "off"
      },
      "suspicious": {
        "noConsole": { "level": "off", "options": { "allow": ["debug", "info", "warn", "error"] } },
        "noReactSpecificProps": "off",
        "noEmptyBlockStatements": "off"
      },
      "security": {
        "noSecrets": "off"
      }
    }
  },
  "formatter": { "lineWidth": 120, "indentStyle": "space" },
  "javascript": {
    "formatter": { "quoteStyle": "single", "arrowParentheses": "always", "bracketSameLine": false },
    "linter": { "enabled": true }
  },
  "files": {
    "includes": ["**", "!**/dist"]
  }
}
